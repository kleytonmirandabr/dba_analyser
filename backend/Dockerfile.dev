FROM node:22-alpine

# Install docker CLI for VPN container management
RUN apk add --no-cache docker-cli

# Fix docker socket permissions: create docker group and add node user
RUN addgroup -S docker 2>/dev/null || true && addgroup node docker 2>/dev/null || true

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install

COPY tsconfig.json ./
COPY src ./src

EXPOSE 3030

# Run as root in dev to ensure docker socket access
USER root

CMD ["npm", "run", "dev"]
