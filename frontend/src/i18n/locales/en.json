    "articles": {
      "createConnection": {
        "title": "Create a connection",
        "content": "Go to Connections → New. Fill in: name, host, port, type (SQL Server or PostgreSQL), database, credentials. Test before saving. For VPN access, configure the VPN module first."
      },
      "testConnection": {
        "title": "Test a connection",
        "content": "In the connections list, click the lightning icon. The system tests TCP + authentication + simple query. Result: OK or detailed error message."
      },
      "multiDatabase": {
        "title": "Multi-database",
        "content": "Each connection points to ONE database. To monitor multiple databases on the same server, create one connection per database. Use \"Select Databases\" for batch creation."
      },
      "executeQuery": {
        "title": "Execute a query",
        "content": "Open Query → select connection → type SQL → Ctrl+Enter or Execute button. Results appear below with row count and execution time."
      },
      "multiTab": {
        "title": "Multi-tab queries",
        "content": "Each tab is independent (connection, SQL, result). Add tabs with +. Rename with double-click. Close with X. Favorites save query + name."
      },
      "exportResults": {
        "title": "Export results",
        "content": "After execution, click Export (CSV, JSON, Excel). Results are downloaded with the tab name as filename."
      },
      "monitor": {
        "title": "Session monitor",
        "content": "Select one or more databases → see active sessions in real-time. Kill to terminate session. Filter by app, user, query."
      },
      "alerts": {
        "title": "Configure alerts",
        "content": "Alerts → New. Choose metric (CPU, sessions, deadlocks, custom query), condition (>, <, =), threshold and severity. Check interval sets frequency."
      },
      "softDelete": {
        "title": "Soft delete and audit",
        "content": "NOTHING is permanently deleted. Every operation (create, modify, delete) records: who did it, when, and the diff (old value → new). Access in Audit."
      },
      "configureVPN": {
        "title": "Configure VPN",
        "content": "Upload the .ovpn file (OpenVPN) in VPN → Upload. Click Connect. Status shows in toolbar. VPN-routed connections access internal servers."
      }
    }
