    "articles": {
      "createConnection": {
        "title": "Criar uma conexão",
        "content": "Vá em Conexões → Novo. Preencha: nome, host, porta, tipo (SQL Server ou PostgreSQL), database, credenciais. Teste antes de salvar. Para acesso via VPN, configure primeiro o módulo VPN."
      },
      "testConnection": {
        "title": "Testar uma conexão",
        "content": "Na lista de conexões, clique no ícone de raio. O sistema testa TCP + autenticação + query simples. Resultado: OK ou mensagem de erro detalhada."
      },
      "multiDatabase": {
        "title": "Multi-database",
        "content": "Cada conexão aponta para UM database. Para monitorar vários databases do mesmo servidor, crie uma conexão por database. Use \"Selecionar Databases\" para criar em lote."
      },
      "executeQuery": {
        "title": "Executar uma query",
        "content": "Abra Query → selecione conexão → digite SQL → Ctrl+Enter ou botão Executar. Resultados aparecem abaixo com contagem de linhas e tempo de execução."
      },
      "multiTab": {
        "title": "Multi-tab de queries",
        "content": "Cada aba é independente (conexão, SQL, resultado). Adicione abas com +. Renomeie com duplo-clique. Feche com X. Favoritos salvam query + nome."
      },
      "exportResults": {
        "title": "Exportar resultados",
        "content": "Após executar, clique em Export (CSV, JSON, Excel). Os resultados são baixados com o nome da aba como arquivo."
      },
      "monitor": {
        "title": "Monitor de sessões",
        "content": "Selecione um ou mais bancos → ver sessões ativas em tempo real. Kill para encerrar sessão. Filtro por app, user, query."
      },
      "alerts": {
        "title": "Configurar alertas",
        "content": "Alertas → Novo. Escolha métrica (CPU, sessões, deadlocks, custom query), condição (>, <, =), threshold e severidade. Check interval define frequência."
      },
      "softDelete": {
        "title": "Soft delete e auditoria",
        "content": "NADA é deletado permanentemente. Toda operação (criar, alterar, excluir) grava: quem fez, quando, e o diff (valor antigo → novo). Acesse em Auditoria."
      },
      "configureVPN": {
        "title": "Configurar VPN",
        "content": "Faça upload do arquivo .ovpn (OpenVPN) em VPN → Upload. Clique Conectar. O status aparece na toolbar. Conexões roteadas pela VPN acessam servidores internos."
      }
    }
  },
