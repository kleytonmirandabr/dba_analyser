# ══════════════════════════════════════════
# DBA Analyser - Environment Variables
# ══════════════════════════════════════════
# Copie este arquivo para .env e configure:
# cp .env.example .env

# Master key para encriptação de credenciais (AES-256-GCM)
# Gerar com: openssl rand -hex 32
DBA_MASTER_KEY=your-master-key-here

# Secret para assinatura de tokens JWT
# Gerar com: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here

# ══════════════════════════════════════════
# PostgreSQL (banco interno do sistema)
# ══════════════════════════════════════════
POSTGRES_DB=dba_analyser
POSTGRES_USER=dba_app
POSTGRES_PASSWORD=dba_secret
POSTGRES_PORT=5433

# ══════════════════════════════════════════
# Node.js
# ══════════════════════════════════════════
NODE_ENV=development

# ══════════════════════════════════════════
# Frontend (Vite)
# ══════════════════════════════════════════
VITE_API_URL=
