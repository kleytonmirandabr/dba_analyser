# Banco interno do DBA Analyser
DATABASE_URL=postgresql://dba_app:sua_senha_aqui@postgres:5432/dba_analyser
DB_PASSWORD=sua_senha_aqui

# Chave mestra para criptografia de credenciais (gerar com: openssl rand -hex 32)
DBA_MASTER_KEY=gerar_com_openssl_rand_hex_32

# JWT Secret (gerar com: openssl rand -hex 32)
JWT_SECRET=gerar_com_openssl_rand_hex_32

# Ambiente
NODE_ENV=production
PORT=3030

# Alertas (opcional)
# ALERT_EMAIL_SMTP=smtp://user:pass@smtp.gmail.com:587
# ALERT_WEBHOOK_URL=https://hooks.slack.com/...
